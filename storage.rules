rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos
    match /profile_photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Chat media
    match /chat_media/{chatId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024;
    }

    // Stories
    match /stories/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 500 * 1024 * 1024;
    }

    // Group photos
    match /group_photos/{groupId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Stickers
    match /stickers/{userId}/{packId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Support
    match /support/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // AI temp
    match /ai_temp/{fileName} {
      allow read, write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024;
    }
  }
}